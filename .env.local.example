# Copy this file to .env.local and fill in real values for local dev.
# When deploying to Vercel, paste these into the Vercel project's
# Environment Variables settings (NOT into the file).

# Pick any password you want — share it with your team.
DASHBOARD_PASSWORD=changeme

# Random secret used to sign auth cookies. Generate with:
#   openssl rand -base64 32
# Or any other long random string. Keep it private.
SESSION_SECRET=replace-with-a-long-random-string

# Required: the Google Sheet ID to read from. Get it from the sheet URL between /d/ and /edit.
GOOGLE_SHEET_ID=
